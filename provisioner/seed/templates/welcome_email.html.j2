<!DOCTYPE html>
<html lang="en">
<body style="font-family:sans-serif;max-width:600px;margin:auto;padding:24px;color:#111">
  <h1 style="color:#1a1a2e">Welcome to {{ company.company_name }}, {{ employee.first_name }}!</h1>
  <p>Your account is ready. <a href="https://{{ company.company_id }}.{{ company.root_domain }}">Log in here</a>.</p>

  <h2>Your apps</h2>
  <ul>
    {% for app in employee.apps %}
    <li><a href="https://{{ app }}.{{ company.company_id }}.{{ company.root_domain }}">{{ app | title }}</a></li>
    {% endfor %}
  </ul>

  <h2>Your onboarding pack</h2>
  <p>
    Find it in
    <a href="https://files.{{ company.company_id }}.{{ company.root_domain }}">Files</a>
    under <code>/onboarding/{{ employee.first_name }}_{{ employee.last_name }}/</code>
  </p>

  {% if manager %}
  <h2>Your manager</h2>
  <p>
    <strong>{{ manager.first_name }} {{ manager.last_name }}</strong> —
    <a href="mailto:{{ manager.email }}">{{ manager.email }}</a><br>
    You have a 1:1 already on your calendar.
  </p>
  {% endif %}

  <hr style="margin:32px 0;border:none;border-top:1px solid #ddd">
  <p style="font-size:12px;color:#666">
    Questions? Contact IT at
    <a href="https://auth.{{ company.company_id }}.{{ company.root_domain }}">auth.{{ company.company_id }}.{{ company.root_domain }}</a>
  </p>
</body>
</html>
