# .env.example — copy to .env and fill in your secret values
#
# .env is gitignored and must NEVER be committed.
# Non-secret settings belong in freeit.yaml.

# OpenTofu state encryption passphrase (AES-GCM + PBKDF2)
FREEIT_STATE_PASSPHRASE=

# Cloudflare API token — Zone:DNS:Edit permission for your domain
FREEIT_CLOUDFLARE_API_TOKEN=
